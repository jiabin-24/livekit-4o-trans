# ===========================================
# Azure OpenAI (STT: gpt-4o-transcribe, LLM: gpt-4o / gpt-4o-mini)
# ===========================================
AZURE_OPENAI_ENDPOINT=https://admin-mfvtt29u-eastus2.openai.azure.com
AZURE_OPENAI_API_VERSION=2025-04-01-preview
AZURE_OPENAI_STT_DEPLOYMENT=gpt-4o-transcribe # gpt-realtime-whisper, gpt-4o-transcribe
AZURE_OPENAI_LLM_DEPLOYMENT=gpt-4o-mini
AUTO_GREETING=1

# 可选：使用 API Key 认证（留空则使用 DefaultAzureCredential / Entra ID）
AZURE_OPENAI_API_KEY=

# STT 语言（zh / en / ...）
STT_LANGUAGE=zh

# ===========================================
# Azure Speech TTS
# ===========================================
AZURE_SPEECH_REGION=eastus2 # swedencentral
AZURE_SPEECH_RESOURCE_ENDPOINT=https://admin-mfvtt29u-eastus2.cognitiveservices.azure.com
#AZURE_SPEECH_KEY=
AZURE_TTS_VOICE=zh-CN-XiaoxiaoNeural
